{
  "dataRoles": [
    {
      "displayName": "X Axis",
      "name": "category",
      "kind": "Grouping",
      "description": "Categorical field rendered as grid columns"
    },
    {
      "displayName": "Y Axis",
      "name": "series",
      "kind": "Grouping",
      "description": "Categorical field rendered as grid rows"
    },
    {
      "displayName": "Value",
      "name": "measure",
      "kind": "Measure",
      "description": "Numeric measure that drives each cell's color intensity"
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "category": { "min": 0, "max": 1 },
          "series": { "min": 0, "max": 1 },
          "measure": { "min": 0, "max": 1 }
        }
      ],
      "categorical": {
        "categories": {
          "for": { "in": "category" },
          "dataReductionAlgorithm": { "top": { "count": 200 } }
        },
        "values": {
          "group": {
            "by": "series",
            "select": [
              { "for": { "in": "measure" } }
            ],
            "dataReductionAlgorithm": { "top": { "count": 200 } }
          }
        }
      }
    }
  ],
  "objects": {
    "colorGradient": {
      "properties": {
        "colorMin": { "type": { "fill": { "solid": { "color": true } } } },
        "colorLow": { "type": { "fill": { "solid": { "color": true } } } },
        "colorMid": { "type": { "fill": { "solid": { "color": true } } } },
        "colorHigh": { "type": { "fill": { "solid": { "color": true } } } },
        "colorMax": { "type": { "fill": { "solid": { "color": true } } } }
      }
    },
    "cells": {
      "properties": {
        "showBorder": { "type": { "bool": true } },
        "borderColor": { "type": { "fill": { "solid": { "color": true } } } }
      }
    },
    "dataLabels": {
      "properties": {
        "show": { "type": { "bool": true } },
        "fontFamily": { "type": { "text": true } },
        "fontSize": { "type": { "numeric": true } },
        "fontColor": { "type": { "fill": { "solid": { "color": true } } } }
      }
    },
    "xAxis": {
      "properties": {
        "show": { "type": { "bool": true } },
        "fontSize": { "type": { "numeric": true } },
        "fontColor": { "type": { "fill": { "solid": { "color": true } } } },
        "labelRotation": { "type": { "numeric": true } }
      }
    },
    "yAxis": {
      "properties": {
        "show": { "type": { "bool": true } },
        "fontSize": { "type": { "numeric": true } },
        "fontColor": { "type": { "fill": { "solid": { "color": true } } } }
      }
    },
    "legend": {
      "properties": {
        "show": { "type": { "bool": true } },
        "position": {
          "type": {
            "enumeration": [
              { "value": "Top", "displayName": "Top" },
              { "value": "Bottom", "displayName": "Bottom" },
              { "value": "Right", "displayName": "Right" }
            ]
          }
        }
      }
    }
  },
  "privileges": [],
  "supportsLandingPage": false,
  "supportsEmptyDataView": false,
  "supportsSynchronizingFilterState": true
}
